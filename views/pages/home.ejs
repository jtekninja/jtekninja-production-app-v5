<%- include('../partials/header') %>

<section class="hero hero-home profile-hero luxury-hero">
  <div class="container hero-inner luxury-hero-inner">
    <div class="hero-copy luxury-copy">
      <p class="hero-kicker">Personal profile</p>
      <h1>Sanjai Syamaprasad</h1>
      <p class="hero-tagline">Developer · Builder · Entrepreneur</p>
      <p class="hero-subtitle">
        I build digital products, explore automation, and work at the intersection of software,
        entrepreneurship, and digital growth. This site is a refined home base for what I am building,
        what I care about, and where I am headed next.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#about">About Me</a>
        <a class="btn btn-secondary" href="#contact">Connect</a>
      </div>


      <div class="premium-social-bar" aria-label="Social links">
        <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" class="social-pill social-tiktok" aria-label="TikTok">
          <span class="social-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.5 3c.4 1.9 1.8 3.5 3.7 4.2.7.3 1.5.4 2.3.4v3.2c-1 0-2-.2-2.9-.5-.8-.3-1.6-.8-2.3-1.4v7.2c0 1.6-.6 3.1-1.8 4.2a6.1 6.1 0 0 1-4.3 1.7 6 6 0 0 1-4.3-1.8A6 6 0 0 1 3 16c0-1.6.6-3.1 1.8-4.2a6.1 6.1 0 0 1 4.3-1.7c.4 0 .8 0 1.2.1v3.2a3.3 3.3 0 0 0-1.2-.2c-.8 0-1.5.3-2 .8a2.8 2.8 0 0 0-.8 2c0 .8.3 1.5.8 2s1.3.8 2 .8c.8 0 1.5-.3 2-.8s.8-1.3.8-2V3h3.6Z" fill="currentColor"/></svg>
          </span>
          <span>TikTok</span>
        </a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="social-pill social-instagram" aria-label="Instagram">
          <span class="social-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm0 2.5A2.5 2.5 0 0 0 4.5 7v10A2.5 2.5 0 0 0 7 19.5h10a2.5 2.5 0 0 0 2.5-2.5V7A2.5 2.5 0 0 0 17 4.5H7Zm10.8 1.3a1 1 0 1 1 0 2.1 1 1 0 0 1 0-2.1ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2.3a2.7 2.7 0 1 0 0 5.4 2.7 2.7 0 0 0 0-5.4Z" fill="currentColor"/></svg>
          </span>
          <span>Instagram</span>
        </a>
        <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" class="social-pill social-youtube" aria-label="YouTube">
          <span class="social-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.6 7.2a2.8 2.8 0 0 0-2-2c-1.8-.5-7.6-.5-7.6-.5s-5.8 0-7.6.5a2.8 2.8 0 0 0-2 2A29 29 0 0 0 2 12a29 29 0 0 0 .4 4.8 2.8 2.8 0 0 0 2 2c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a2.8 2.8 0 0 0 2-2A29 29 0 0 0 22 12a29 29 0 0 0-.4-4.8ZM10 15.5v-7l6 3.5-6 3.5Z" fill="currentColor"/></svg>
          </span>
          <span>YouTube</span>
        </a>
      </div>


      <div class="hero-trust-row luxury-trust-row">
        <span>Software</span>
        <span>E-commerce</span>
        <span>Growth</span>
      </div>

      <div class="founder-note glass-card founder-note-card">
        <p class="section-mini">Perspective</p>
        <p>I am focused on building a body of work that feels thoughtful, modern, and durable — not just functional.</p>
      </div>
    </div>

    <div class="hero-status luxury-focus-card">
      <p class="card-tag">Current focus</p>
      <div class="status-row">
        <span>Building</span>
        <strong>Web apps & tools</strong>
      </div>
      <div class="status-row">
        <span>Exploring</span>
        <strong>Digital commerce</strong>
      </div>
      <div class="status-row">
        <span>Learning</span>
        <strong>Organic content systems</strong>
      </div>
      <div class="status-row wide-row">
        <span>Direction</span>
        <strong>Creating practical digital businesses over time</strong>
      </div>
    </div>
  </div>
</section>

<section id="about" class="section section-tight">
  <div class="container split-grid luxury-split">
    <div>
      <p class="section-mini">About</p>
      <h2>Building with technology, taste, and long-term thinking</h2>
      <p>
        I am a tech-focused builder with a strong interest in turning ideas into practical digital products.
        My work sits at the intersection of software, online business, and execution.
      </p>
      <p>
        I am especially drawn to projects where I can combine technical problem-solving with real-world learning,
        whether that means creating a cleaner web app, testing a store concept, or improving how digital products grow.
      </p>
    </div>
    <div class="glass-card info-panel luxury-panel">
      <p class="section-mini">Approach</p>
      <h3>What defines my work</h3>
      <ul class="clean-list">
        <li>Fast iteration with practical execution</li>
        <li>Interest in both products and distribution</li>
        <li>Clean design with strong functionality</li>
        <li>Long-term focus on digital assets</li>
      </ul>
    </div>
  </div>
</section>

<section id="ventures" class="section alt luxury-alt">
  <div class="container">
    <div class="section-heading luxury-heading">
      <p class="section-mini">Focus</p>
      <h2>What I am building around right now</h2>
      <p>A focused mix of technical execution, business exploration, and disciplined iteration.</p>
    </div>

    <div class="cards-3 luxury-card-grid">
      <article class="card glass-card venture-card luxury-card">
        <p class="card-tag">Software</p>
        <h3>Web Apps & Automation</h3>
        <p>Building Node.js projects, dashboards, and tools that solve practical workflow problems.</p>
      </article>

      <article class="card glass-card venture-card luxury-card">
        <p class="card-tag">Commerce</p>
        <h3>E-commerce Exploration</h3>
        <p>Learning product research, cleaner offer positioning, and stronger store fundamentals.</p>
      </article>

      <article class="card glass-card venture-card luxury-card">
        <p class="card-tag">Growth</p>
        <h3>Content & Traffic</h3>
        <p>Studying hooks, distribution, and organic systems that drive attention online.</p>
      </article>
    </div>
  </div>
</section>

<section id="stack" class="section">
  <div class="container">
    <div class="section-heading luxury-heading">
      <p class="section-mini">Capabilities</p>
      <h2>Capabilities I continue to sharpen</h2>
      <p>A growing foundation across product, engineering, design, and digital growth.</p>
    </div>

    <div class="cards-4 stat-grid luxury-stat-grid">
      <div class="card glass-card stat-card luxury-card"><strong>Node.js</strong><span>Backend apps and APIs</span></div>
      <div class="card glass-card stat-card luxury-card"><strong>MongoDB</strong><span>Data models and app structure</span></div>
      <div class="card glass-card stat-card luxury-card"><strong>UI / UX</strong><span>Clean, modern interface direction</span></div>
      <div class="card glass-card stat-card luxury-card"><strong>Growth Systems</strong><span>Traffic, testing, and iteration</span></div>
    </div>
  </div>
</section>

<section id="contact" class="section alt contact-upgrade luxury-alt">
  <div class="container luxury-contact-wrap">
    <div class="section-heading center-heading luxury-heading">
      <p class="section-mini">Connect</p>
      <h2>Start a conversation</h2>
      <p>If you want to reach out about a project, collaboration, or idea, you can send a message here.</p>
    </div>

    <div class="split-grid contact-grid luxury-contact-grid">
      <div class="contact-side-stack">
        <div class="contact-command-card glass-card luxury-card">
          <p class="section-mini">Profile</p>
          <h3>Personal first. Professional by design.</h3>
          <p>
            This page is meant to feel like a refined digital profile — focused on work, ideas,
            curiosity, and where those things may lead next.
          </p>
        </div>

        <div class="contact-points contact-points-upgraded">
          <div class="point-card glass-card luxury-card">
            <strong>Projects</strong>
            <span>Software ideas, product experiments, and digital business concepts.</span>
          </div>
          <div class="point-card glass-card luxury-card">
            <strong>Interests</strong>
            <span>Technology, entrepreneurship, digital products, and organic growth.</span>
          </div>
          <div class="point-card glass-card luxury-card">
            <strong>Connections</strong>
            <span>Open to conversations that lead to learning, opportunities, or collaboration.</span>
          </div>
        </div>
      </div>

      <form class="card glass-card form-card luxury-form-card" action="/contact" method="POST">
        <div class="form-topline">
          <p class="section-mini">Direct message</p>
          <h3>Reach out</h3>
          <p class="muted-copy">Introduce yourself and share what you have in mind.</p>
        </div>

        <label>Name<input type="text" name="name" required /></label>
        <label>Email<input type="email" name="email" required /></label>
        <label>Phone<input type="text" name="phone" /></label>
        <label>Reason for reaching out
          <select name="businessInterest">
            <option value="">Select one</option>
            <option>Software / Web Project</option>
            <option>Business Collaboration</option>
            <option>Content / Growth</option>
            <option>General Inquiry</option>
          </select>
        </label>
        <label>Message<textarea name="message" rows="5" required></textarea></label>
        <button class="btn btn-primary" type="submit">Send Message</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
