NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# Admin login for dashboard
ADMIN_EMAIL=admin@jtekninja.com
ADMIN_PASSWORD=change_this_now
SESSION_SECRET=replace_with_a_long_random_string

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/jtekninja?retryWrites=true&w=majority&appName=Cluster0

# Gmail SMTP using Google App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=jtekninja@gmail.com
EMAIL_PASS=your_16_char_google_app_password
EMAIL_FROM="JTekNinja Alerts <jtekninja@gmail.com>"
ALERT_TO=jtekninja@gmail.com

# Portfolio links (optional)
TIKTOK_URL=https://www.tiktok.com/@jtekninja
INSTAGRAM_URL=https://www.instagram.com/yourhandle
YOUTUBE_URL=https://www.youtube.com/@yourhandle
SHOP_URL=https://yourstore.example.com
GITHUB_URL=https://github.com/yourusername
